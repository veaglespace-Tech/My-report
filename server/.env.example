## Copy this file to .env for local development.
## Never commit real production secrets.

# Database
DB_URL=jdbc:mysql://127.0.0.1:3306/myreport_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-before-production
JWT_EXPIRATION_MS=86400000
JWT_REMEMBER_EXPIRATION_MS=604800000

# Seeded super admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe@12345

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_FROM=
SMTP_ENVELOPE_FROM=
SMTP_FROM_NAME=MyReport
SMTP_PASS=
