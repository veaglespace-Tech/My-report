## Copy this file to .env for local development.
## Never commit real production secrets.

SPRING_APPLICATION_NAME=myreport-server
SERVER_PORT=8082

# Database
DB_URL=jdbc:mysql://127.0.0.1:3306/myreport_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root

# JPA / schema migrations
JPA_HIBERNATE_DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_OPEN_IN_VIEW=false
JPA_FORMAT_SQL=false
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=0
FLYWAY_VALIDATE_ON_MIGRATE=true

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-before-production
JWT_EXPIRATION_MS=86400000
JWT_REMEMBER_EXPIRATION_MS=604800000

# Seeded super admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe@12345

# Frontend / backend
FRONTEND_URL=http://localhost:3004
FRONTEND_ORIGIN=http://localhost:3004
BACKEND_URL=http://localhost:8082

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# PayU
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_BASE_URL=https://test.payu.in/_payment

# SMTP
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourgmail@gmail.com
# SMTP_FROM=yourgmail@gmail.com
# SMTP_ENVELOPE_FROM=yourgmail@gmail.com
# SMTP_AUTH=true
# SMTP_SSL_ENABLE=false
# SMTP_STARTTLS_ENABLE=true
# SMTP_STARTTLS_REQUIRED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_FROM=
SMTP_ENVELOPE_FROM=
SMTP_FROM_NAME=MyReport
SMTP_PASS=
SMTP_AUTH=true
SMTP_SSL_ENABLE=false
SMTP_STARTTLS_ENABLE=true
SMTP_STARTTLS_REQUIRED=true
